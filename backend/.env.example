# Database configuration
DATABASE_URL="postgresql://user:password@localhost:5432/budget_db?schema=public"

# Server configuration
PORT=5000
NODE_ENV=development

# Security
JWT_SECRET="your_at_least_256_bit_secret_string_here"
JWT_REFRESH_SECRET="your_refresh_token_secret_string_here"
CORS_ORIGIN="http://localhost:5173"

# Email (SMTP)
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_USER="your_email@example.com"
SMTP_PASS="your_password"
SMTP_FROM="Budget Tracker <noreply@example.com>"
